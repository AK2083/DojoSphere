# =============================================================================
# DojoSphere environment variables
# Copy to `.env.development` for local work or adjust per mode (`.env.e2e`, `.env.test`).
# Defaults for ports and host: `config/dev.json` (overridable via the variables below).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (renderer)
# -----------------------------------------------------------------------------

# Supabase project URL used by the Vue app.
# VITE_SUPABASE_URL=http://127.0.0.1:54321

# Supabase publishable (anon) key — safe to expose in the client.
# VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# -----------------------------------------------------------------------------
# Telemetry (main process — Phase 1 local collector)
# -----------------------------------------------------------------------------

# Local OpenTelemetry capture uses a collector on 127.0.0.1:4318.
# Trace batches are written to <userData>/telemetry/traces.jsonl.
# Grafana Cloud export is configured in a later phase (main process only).

# -----------------------------------------------------------------------------
# Host and ports (tooling)
# -----------------------------------------------------------------------------

# Host for Vite, Playwright, Storybook, and Vitest browser runs (default: 127.0.0.1).
# VITE_DEV_SERVER_HOST=127.0.0.1

# Vite dev server with Electron (`npm run dev`) — default: 5173.
# VITE_DEV_SERVER_PORT=5173

# Playwright browser test server (`npm run e2e:server`, mode `e2e`) — default: 4173.
# Keep in sync with VITE_DEV_SERVER_PORT in `.env.e2e`.
# E2E_SERVER_PORT=4173

# Storybook component catalog (`npm run storybook`) — default: 6006.
# STORYBOOK_PORT=6006

# Vitest browser runner for Storybook tests — default: 42123.
# VITEST_STORYBOOK_BROWSER_PORT=42123

# Chromium remote debugging when Electron starts (default: 9223).
# ELECTRON_REMOTE_DEBUG_PORT=9223

# Node.js inspector for the Electron main process (default: 9229).
# ELECTRON_INSPECT_PORT=9229

# -----------------------------------------------------------------------------
# Playwright browser-only mode (see `.env.e2e`)
# -----------------------------------------------------------------------------

# When `true`, Vite serves only the renderer in a browser: Electron is not started
# and `window.api` is mocked (used by `npm run test:e2e` locally and in CI).
# VITE_PLAYWRIGHT_BROWSER_ONLY=true
