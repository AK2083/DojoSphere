{
  "name": "dojosphere",
  "version": "0.0.0",
  "description": "Open-source Electron application for managing Judo tournaments.",
  "keywords": [
    "judo",
    "tournament"
  ],
  "homepage": "https://github.com/AK2083/DojoSphere#readme",
  "bugs": {
    "url": "https://github.com/AK2083/DojoSphere/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Adrian Helmchen",
    "url": "https://github.com/AK2083"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AK2083/DojoSphere.git"
  },
  "private": true,
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=24"
  },
  "sideEffects": false,
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:start": "vite",
    "e2e:server": "vite --mode e2e",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "type:check": "vue-tsc --build --noEmit && tsc -p tsconfig.main.json --noEmit",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "vitest",
    "test:main": "vitest --project main",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:init": "supabase init",
    "storybook": "node scripts/storybook.mjs",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@mdi/js": "^7.4.47",
    "@sentry/vue": "^10.55.0",
    "@supabase/supabase-js": "^2.106.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.1.0",
    "vuetify": "^4.0.8"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@mdi/font": "^7.4.47",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/vue3-vite": "^10.4.1",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^42.3.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-storybook": "^10.4.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.1",
    "supabase": "^2.101.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.2"
  }
}
